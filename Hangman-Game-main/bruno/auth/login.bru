meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/auth/login
  body: json
  auth: none
}

body:json {
  {
    "email": "barbara@test.com",
    "password": "123456"
  }
}

script:post-response {
  const token = res.getBody().token;
  if (token) {
    bru.setEnvVar("token", token);
  }
}
